{
  "schemaVersion": 1,
  "layout": "agenda_list",
  "colors": {
    "background": { "type": "image_blur", "url": null, "blurRadius": 24, "fallback": "#C9D2DA" },
    "panel": "#EAF0F4",
    "panelOpacityPast": 0.6,
    "panelBorder": "#D2DAE2",
    "headerAccentBar": "#E8B600",
